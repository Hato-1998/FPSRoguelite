# =============================================================================
# Unreal Engine 5 — .gitignore (범용 템플릿)
# 사용법: 프로젝트 루트에 복사
# =============================================================================

# =============================================================================
# UE5 Generated / Intermediate
# =============================================================================
Binaries/
Plugins/**/Binaries/
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/
ShaderCache/

# Live Coding
*.livecodingmanifest
LiveCoding/
.lock-ue4

# Compiled source for the editor
*.generated.h
*.gen.cpp

# =============================================================================
# UE5 Saved (에디터 생성 파일)
# =============================================================================
Saved/

# =============================================================================
# UE5 Build Output
# =============================================================================
Build/
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# =============================================================================
# UE5 Content
# =============================================================================
*_BuiltData.uasset
SourceArt/**/*.png
SourceArt/**/*.tga
FeaturePacks/

# =============================================================================
# Config (에디터 생성 로컬 설정만 제외)
# =============================================================================
Config/Layouts/
Config/Tags/

# =============================================================================
# IDE — Visual Studio
# =============================================================================
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig
*.user
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# =============================================================================
# IDE — JetBrains Rider
# =============================================================================
.idea/
*.DotSettings.user

# =============================================================================
# IDE — VS Code
# =============================================================================
.vscode/
*.code-workspace

# =============================================================================
# IDE — Xcode (macOS)
# =============================================================================
*.xcodeproj
*.xcworkspace
*.xcuserstate

# =============================================================================
# Compiled Objects / Libraries
# =============================================================================
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.mod
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app
*.ipa

# =============================================================================
# OS 파일
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.lnk

# =============================================================================
# Claude Code (로컬 전용 도구 설정·메타데이터 — 머신 로컬, 공유 금지)
# =============================================================================
.claude/

# =============================================================================
# Codex 코드리뷰 결과 (로컬 전용)
# =============================================================================
Docs/reviews/

# =============================================================================
# 서드파티 툴 플러그인 (게임 산출물 아님 — 로컬 설치, 공유 금지)
# =============================================================================
Plugins/VibeUE/
